{
  "name": "gpa-ftp-deploy",
  "displayName": "FTP Deploy (Network Drive Safe)",
  "description": "Upload files via FTP, FTPS or SFTP directly from VS Code. Built for Windows Samba shares, mapped drives and UNC paths — with multi-profile support and OS keychain password storage.",
  "version": "1.1.0",
  "publisher": "GPAutomation",
  "icon": "images/icon.png",
  "license": "MIT",
  "homepage": "https://gyagix.github.io/gpa-ftp-deploy",
  "repository": {
    "type": "git",
    "url": "https://github.com/gyagix/gpa-ftp-deploy"
  },
  "bugs": {
    "url": "https://github.com/gyagix/gpa-ftp-deploy/issues"
  },
  "sponsor": {
    "url": "https://buymeacoffee.com/gpautomation"
  },
  "keywords": [
    "ftp", "sftp", "ftps", "upload", "deploy",
    "network drive", "samba", "remote", "sync"
  ],
  "categories": ["Other"],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "engines": { "vscode": "^1.80.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "ftpDeploy.selectProfile",  "title": "FTP Deploy: Select profile" },
      { "command": "ftpDeploy.uploadFile",      "title": "FTP Deploy: Upload current file" },
      { "command": "ftpDeploy.uploadFolder",    "title": "FTP Deploy: Upload entire folder" },
      { "command": "ftpDeploy.uploadSelected",  "title": "FTP Deploy: Upload →" },
      { "command": "ftpDeploy.savePassword",    "title": "FTP Deploy: Save password to keychain" },
      { "command": "ftpDeploy.deletePassword",  "title": "FTP Deploy: Remove password from keychain" },
      { "command": "ftpDeploy.testConnection",  "title": "FTP Deploy: Test connection" },
      { "command": "ftpDeploy.showLog",         "title": "FTP Deploy: Show log" },
      { "command": "ftpDeploy.openConfig",      "title": "FTP Deploy: Open workspace config" },
      { "command": "ftpDeploy.addProfile",      "title": "FTP Deploy: Add profile" }
    ],
    "menus": {
      "explorer/context": [
        { "command": "ftpDeploy.uploadSelected", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "ftpDeploy.uploadFile", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "FTP Deploy",
      "properties": {
        "ftpDeploy.profiles": {
          "type": "object",
          "default": {},
          "description": "Connection profiles. Each key is a profile name (e.g. dev, staging, prod).",
          "additionalProperties": {
            "type": "object",
            "required": ["host", "user", "remotePath"],
            "properties": {
              "protocol":           { "type": "string", "enum": ["ftp","ftps","sftp"], "default": "ftp", "description": "Transfer protocol." },
              "host":               { "type": "string", "description": "Remote server hostname or IP." },
              "port":               { "type": "number", "description": "Remote port. Defaults: FTP/FTPS=21, SFTP=22." },
              "user":               { "type": "string", "description": "Login username." },
              "password":           { "type": "string", "description": "Not recommended — use 'Save password to keychain' instead." },
              "remotePath":         { "type": "string", "description": "Absolute path on the remote server." },
              "localRoot":          { "type": "string", "description": "Local root folder. Accepts Z:\\path or \\\\server\\share\\path. Leave empty to use workspace root." },
              "uploadOnSave":       { "type": "boolean", "default": true, "description": "Automatically upload the active file on save." },
              "passive":            { "type": "boolean", "default": true, "description": "[FTP] Use passive mode." },
              "ignore":             { "type": "array", "items": { "type": "string" }, "default": [".git","node_modules",".vs","*.user","Thumbs.db"], "description": "Glob patterns to exclude from upload." },
              "timeout":            { "type": "number", "default": 15000, "description": "Connection timeout in milliseconds." },
              "showNotifications":  { "type": "boolean", "default": true, "description": "Show VS Code notifications on upload." },
              "ftpsImplicit":       { "type": "boolean", "default": false, "description": "[FTPS] true = implicit TLS port 990; false = STARTTLS port 21." },
              "rejectUnauthorized": { "type": "boolean", "default": true, "description": "[FTPS] Set to false only for self-signed certificates." },
              "privateKeyPath":     { "type": "string", "description": "[SFTP] Absolute path to the SSH private key file." },
              "passphrase":         { "type": "string", "description": "[SFTP] Passphrase for the SSH private key." }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "ssh2-sftp-client": "^9.1.0"
  }
}
